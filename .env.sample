# GavaConnect SDK — Environment Variables
# Copy this file to .env and fill in your credentials.

# ── GAVACONNECT KRA OAuth2 Credentials ──────────────────────────────────────────
GAVACONNECT_CLIENT_ID=
GAVACONNECT_CLIENT_SECRET=

# ── GAVACONNECT eTIMS OSCU Headers ──────────────────────────────────────────────
GAVACONNECT_ETIMS_TIN=
GAVACONNECT_ETIMS_BHF_ID=00
GAVACONNECT_ETIMS_CMC_KEY=
GAVACONNECT_ETIMS_APP_ID=

